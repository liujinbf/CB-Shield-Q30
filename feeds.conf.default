# CB-Shield-Q30 Feeds 配置

# OpenWrt 官方 feeds（固定到 23.05 分支）
src-git packages https://git.openwrt.org/feed/packages.git;openwrt-23.05
src-git luci https://git.openwrt.org/project/luci.git;openwrt-23.05
src-git routing https://git.openwrt.org/feed/routing.git;openwrt-23.05

# Passwall（由 diy-part1.sh 做本地 src-link 覆盖）
src-git passwall https://github.com/openwrt-passwall/openwrt-passwall.git;main
src-git passwall_packages https://github.com/openwrt-passwall/openwrt-passwall-packages.git;main

# Argon 主题（由 diy-part1.sh 做本地 src-link 覆盖）
src-git argon https://github.com/jerrykuku/luci-theme-argon.git;master
src-git argon_config https://github.com/jerrykuku/luci-app-argon-config.git;master

# Kwrt 扩展（由 diy-part1.sh 做本地 src-link 覆盖）
src-git kwrt https://github.com/kiddin9/op-packages.git;main
