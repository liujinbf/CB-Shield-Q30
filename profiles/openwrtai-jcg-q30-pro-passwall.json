{
  "name": "CB-Shield Q30 Pro Passwall",
  "target": "mediatek/filogic",
  "profile": "jcg_q30-pro",
  "theme": "argon",
  "webserver": "nginx",
  "filesystem": "squashfs",
  "rootfs_size_mb": 1004,
  "efi": "efi",
  "packages": [
    "luci-theme-argon",
    "luci-nginx",
    "curl",
    "ca-bundle",
    "ca-certificates",
    "luci-app-passwall"
  ],
  "defaults_file": ".work/cbshield-openwrtai-defaults.sh",
  "overlay_file": ".work/cbshield-openwrtai-overlay.tgz",
  "form_defaults": {
    "models": "JCG Q30 PRO",
    "theme": "argon",
    "webserver": "nginx",
    "kernel_v": "6.12.y",
    "fsys": "squashfs",
    "save": true,
    "ipv6": true,
    "dhcp": true,
    "efi": true,
    "passwall": true,
    "openclash": false
  },
  "site_optional_features": [
    {
      "name": "Passwall",
      "field": "passwall",
      "enabled": true,
      "notes": "主代理栈固定为 Passwall。"
    },
    {
      "name": "OpenClash",
      "field": "openclash",
      "enabled": false,
      "notes": "不要与 Passwall 同时启用。"
    }
  ],
  "notes": [
    "适合以 Passwall 作为主代理面板的版本。",
    "UI、Portal 和 cb-* 脚本通过 overlay_file 注入。",
    "默认首页和服务 enable 通过 defaults_file 注入。"
  ]
}
