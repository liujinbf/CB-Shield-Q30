#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG=/usr/sbin/uhttpd

start_service() {
    [ -x "$PROG" ] || return 1

    procd_open_instance "cb-portal"
    procd_set_param command "$PROG" -f -h /www/cb-portal -p 0.0.0.0:8080 -E /www/cb-portal/index.html
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_set_param respawn
    procd_close_instance
}
