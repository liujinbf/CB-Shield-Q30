# CB-Shield-Q30 防火墙配置
# 多店铺隔离 + 管理面保护 + DNS 防泄漏

config defaults
    option syn_flood '1'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option drop_invalid '1'
    option synflood_rate '25'
    option synflood_burst '50'
    option flow_offloading '1'
    option flow_offloading_hw '1'

config zone
    option name 'wan'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option masq '1'
    option mtu_fix '1'
    list network 'wan'

config zone
    option name 'lan'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'ACCEPT'
    list network 'lan'

config zone
    option name 'shop1'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop1'

config zone
    option name 'shop2'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop2'

config zone
    option name 'shop3'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop3'

config zone
    option name 'shop4'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop4'

config zone
    option name 'shop5'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop5'

config forwarding
    option src 'lan'
    option dest 'wan'

config forwarding
    option src 'shop1'
    option dest 'wan'

config forwarding
    option src 'shop2'
    option dest 'wan'

config forwarding
    option src 'shop3'
    option dest 'wan'

config forwarding
    option src 'shop4'
    option dest 'wan'

config forwarding
    option src 'shop5'
    option dest 'wan'

config rule
    option name 'Allow-shop1-DHCP'
    option src 'shop1'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop2-DHCP'
    option src 'shop2'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop3-DHCP'
    option src 'shop3'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop4-DHCP'
    option src 'shop4'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop5-DHCP'
    option src 'shop5'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop1-DNS'
    option src 'shop1'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop2-DNS'
    option src 'shop2'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop3-DNS'
    option src 'shop3'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop4-DNS'
    option src 'shop4'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

config rule
    option name 'Allow-shop5-DNS'
    option src 'shop5'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

config rule
    option name 'Deny-shop1-Admin'
    option src 'shop1'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

config rule
    option name 'Deny-shop2-Admin'
    option src 'shop2'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

config rule
    option name 'Deny-shop3-Admin'
    option src 'shop3'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

config rule
    option name 'Deny-shop4-Admin'
    option src 'shop4'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

config rule
    option name 'Deny-shop5-Admin'
    option src 'shop5'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

config rule
    option name 'Limit-WAN-Ping'
    option src 'wan'
    option proto 'icmp'
    option icmp_type 'echo-request'
    option target 'DROP'

config include
    option path '/etc/firewall.cb-shield'
    option reload '1'

config redirect
    option name 'Hijack-shop1-DNS-UDP'
    option src 'shop1'
    option proto 'udp'
    option src_dport '53'
    option dest_port '53'
    option target 'DNAT'

config redirect
    option name 'Hijack-shop1-DNS-TCP'
    option src 'shop1'
    option proto 'tcp'
    option src_dport '53'
