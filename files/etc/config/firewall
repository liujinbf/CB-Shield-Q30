# CB-Shield-Q30 防火墙配置
# 单网络双频方案：仅保留 LAN / WAN 和基础防护

config defaults
    option syn_flood '1'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option drop_invalid '1'
    option synflood_rate '25'
    option synflood_burst '50'
    option flow_offloading '1'
    option flow_offloading_hw '1'

config zone
    option name 'wan'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option masq '1'
    option mtu_fix '1'
    list network 'wan'

config zone
    option name 'lan'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'ACCEPT'
    list network 'lan'

config forwarding
    option src 'lan'
    option dest 'wan'

config rule
    option name 'Limit-WAN-Ping'
    option src 'wan'
    option proto 'icmp'
    option icmp_type 'echo-request'
    option target 'DROP'

config include
    option path '/etc/firewall.cb-shield'
    option reload '1'
