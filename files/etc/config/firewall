# ============================================================
# CB-Shield-Q30 防火墙配置
# - 多店铺绝对物理隔离 (Shop1 - Shop5)
# - DDoS/端口扫描防护
# ============================================================

config defaults
    option syn_flood '1'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option drop_invalid '1'
    option synflood_rate '25'
    option synflood_burst '50'
    option flow_offloading '1'
    option flow_offloading_hw '1'

# --- Zone: WAN ---
config zone
    option name 'wan'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    option masq '1'
    option mtu_fix '1'
    list network 'wan'

# --- Zone: LAN 主网络 (办公/管理) ---
config zone
    option name 'lan'
    option input 'ACCEPT'
    option output 'ACCEPT'
    option forward 'ACCEPT'
    list network 'lan'

# === 跨境店铺独立隔离域 (Shop1 - Shop5) ===

config zone
    option name 'shop1'
    option input 'REJECT'  
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop1'

config zone
    option name 'shop2'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop2'

config zone
    option name 'shop3'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop3'

config zone
    option name 'shop4'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop4'

config zone
    option name 'shop5'
    option input 'REJECT'
    option output 'ACCEPT'
    option forward 'REJECT'
    list network 'shop5'

# --- Forwarding 规则 (仅允许向 WAN 出口转发) ---
config forwarding
    option src 'lan'
    option dest 'wan'
config forwarding
    option src 'shop1'
    option dest 'wan'
config forwarding
    option src 'shop2'
    option dest 'wan'
config forwarding
    option src 'shop3'
    option dest 'wan'
config forwarding
    option src 'shop4'
    option dest 'wan'
config forwarding
    option src 'shop5'
    option dest 'wan'

# --- 基础规则 (允许必须的基础服务) ---

# 允许各店铺网络访问 DHCP 端口
config rule
    option name 'Allow-Shops-DHCP'
    list src 'shop1'
    list src 'shop2'
    list src 'shop3'
    list src 'shop4'
    list src 'shop5'
    option dest_port '67 68'
    option proto 'udp'
    option target 'ACCEPT'

# 允许各店铺网络访问 DNS
config rule
    option name 'Allow-Shops-DNS'
    list src 'shop1'
    list src 'shop2'
    list src 'shop3'
    list src 'shop4'
    list src 'shop5'
    option dest_port '53'
    option proto 'tcp udp'
    option target 'ACCEPT'

# --- 严格物理隔离: 阻断店铺设备访问管理后台 (LuCI/SSH) ---
config rule
    option name 'Deny-Shops-Admin-Access'
    list src 'shop1'
    list src 'shop2'
    list src 'shop3'
    list src 'shop4'
    list src 'shop5'
    option dest_port '22 80 443'
    option proto 'tcp'
    option target 'REJECT'

# 限制 WAN 入站 Ping
config rule
    option name 'Limit-WAN-Ping'
    option src 'wan'
    option proto 'icmp'
    option icmp_type 'echo-request'
    option target 'DROP'

# --- DDoS 防护规则钩子 ---
config include
    option path '/etc/firewall.cb-shield'
    option reload '1'

# --- DNS 防泄漏劫持 (强制所有店铺域名解析走向代理) ---
config redirect
    option name 'Hijack-Shops-DNS-UDP'
    list src 'shop1'
    list src 'shop2'
    list src 'shop3'
    list src 'shop4'
    list src 'shop5'
    option proto 'udp'
    option src_dport '53'
    option dest_port '53'
    option target 'DNAT'

config redirect
    option name 'Hijack-Shops-DNS-TCP'
    list src 'shop1'
    list src 'shop2'
    list src 'shop3'
    list src 'shop4'
    list src 'shop5'
    option proto 'tcp'
    option src_dport '53'
    option dest_port '53'
    option target 'DNAT'
