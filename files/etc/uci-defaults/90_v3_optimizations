#!/bin/sh
# CB-Shield first boot defaults

uci -q batch <<'EOF'
set luci.main.lang='zh_cn'
set luci.main.mediaurlbase='/luci-static/argon'
set luci.main.homepage='admin/cbshield/dashboard'
set luci.themes.Argon='/luci-static/argon'
commit luci

set system.@system[0].hostname='CB-Shield-Q30'
set system.@system[0].timezone='CST-8'
set system.@system[0].zonename='Asia/Shanghai'
delete system.ntp.server
add_list system.ntp.server='time.cloudflare.com'
add_list system.ntp.server='time.google.com'
add_list system.ntp.server='pool.ntp.org'
commit system

set network.lan.ipaddr='192.168.10.1'
commit network

set dhcp.@dnsmasq[0].cachesize='1500'
commit dhcp
EOF

# shop networks
for i in 1 2 3 4 5; do
    uci -q batch <<EOF
set network.shop$i=interface
set network.shop$i.proto='static'
set network.shop$i.ipaddr='192.168.10$i.1'
set network.shop$i.netmask='255.255.255.0'
set network.shop$i.disabled='1'

set dhcp.shop$i=dhcp
set dhcp.shop$i.interface='shop$i'
set dhcp.shop$i.start='10'
set dhcp.shop$i.limit='50'
set dhcp.shop$i.leasetime='12h'
set dhcp.shop$i.ignore='1'
commit network
commit dhcp
EOF
done

# shop http redirect to local portal
cat <<'EOF' >> /etc/firewall.user
# CB-Shield Portal Redirect
for i in 1 2 3 4 5; do
    iptables -t nat -C PREROUTING -i "shop$i" -p tcp --dport 80 -j DNAT --to-destination :8080 2>/dev/null || \
    iptables -t nat -A PREROUTING -i "shop$i" -p tcp --dport 80 -j DNAT --to-destination :8080
done
EOF

# generate wireless config and enable office wifi
wifi config >/dev/null 2>&1 || wifi detect > /etc/config/wireless
sed -i "s/option country 'US'/option country 'CN'/g" /etc/config/wireless

RADIO0="$(uci -q get wireless.radio0.type)"
RADIO1="$(uci -q get wireless.radio1.type)"

if [ -n "$RADIO0" ]; then
    uci -q batch <<'EOF'
set wireless.radio0.channel='auto'
set wireless.radio0.band='2g'
set wireless.radio0.htmode='HE40'
set wireless.radio0.country='CN'
set wireless.radio0.disabled='0'
set wireless.default_radio0.disabled='0'

set wireless.office_24g=wifi-iface
set wireless.office_24g.device='radio0'
set wireless.office_24g.mode='ap'
set wireless.office_24g.ssid='CB-Shield-Office'
set wireless.office_24g.network='lan'
set wireless.office_24g.encryption='psk2'
set wireless.office_24g.key='CBShield@Office2024'
EOF
fi

if [ -n "$RADIO1" ]; then
    uci -q batch <<'EOF'
set wireless.radio1.channel='auto'
set wireless.radio1.band='5g'
set wireless.radio1.htmode='HE80'
set wireless.radio1.country='CN'
set wireless.radio1.disabled='0'
set wireless.default_radio1.disabled='0'

set wireless.office_5g=wifi-iface
set wireless.office_5g.device='radio1'
set wireless.office_5g.mode='ap'
set wireless.office_5g.ssid='CB-Shield-Office-5G'
set wireless.office_5g.network='lan'
set wireless.office_5g.encryption='psk2'
set wireless.office_5g.key='CBShield@Office2024'
EOF

    for i in 1 2 3 4 5; do
        uci -q batch <<EOF
set wireless.shop${i}_5g=wifi-iface
set wireless.shop${i}_5g.device='radio1'
set wireless.shop${i}_5g.mode='ap'
set wireless.shop${i}_5g.ssid='CB-Shop-0$i'
set wireless.shop${i}_5g.network='shop$i'
set wireless.shop${i}_5g.encryption='psk2'
set wireless.shop${i}_5g.key='Shop$i@Password'
set wireless.shop${i}_5g.isolate='1'
set wireless.shop${i}_5g.disabled='1'
EOF
    done
fi

uci commit wireless
wifi reload >/dev/null 2>&1 || true

# mark wizard required if root password missing
mkdir -p /etc/cbshield
ROOT_HASH="$(grep '^root:' /etc/shadow | cut -d: -f2)"
if [ -z "$ROOT_HASH" ] || [ "$ROOT_HASH" = "*" ] || [ "$ROOT_HASH" = "!" ]; then
    touch /etc/cbshield/wizard_required
    uci -q set cb-wizard.main.required='1'
else
    rm -f /etc/cbshield/wizard_required
    uci -q set cb-wizard.main.required='0'
fi
uci commit cb-wizard

# helper service: randomize shop BSSID each boot
cat <<'EOF' > /etc/init.d/mac_randomizer
#!/bin/sh /etc/rc.common
START=15

start() {
    for i in 1 2 3 4 5; do
        if uci -q get wireless.shop${i}_5g >/dev/null; then
            NEW_MAC="02:$(hexdump -n 5 -e '5/1 "%02x:"' /dev/urandom | sed 's/.$//')"
            uci set wireless.shop${i}_5g.macaddr="$NEW_MAC"
        fi
    done
    uci commit wireless
}
EOF

chmod +x /etc/init.d/mac_randomizer
/etc/init.d/mac_randomizer enable

# enable cb ops services
for svc in cb-riskcontrol cb-portal cb-healthcheck cb-ha-monitor cb-dns-guard cb-policy-engine; do
    /etc/init.d/$svc enable 2>/dev/null
    /etc/init.d/$svc start 2>/dev/null
done

/usr/bin/cb-eventlog write system "first boot defaults applied"

exit 0
